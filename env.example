# Placeholder-only environment template. Do not put real secrets in this file.

# App
APP_ENV=development
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
TIMEZONE=America/Denver
ALLOW_DEMO_DATA=true

# Auth bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<set-in-local-env>
SESSION_SECRET_KEY=<set-in-local-env>
CSRF_SECRET_KEY=<set-in-local-env>

# Database and workers
DATABASE_URL=postgresql+psycopg://stock_picker:<password>@localhost:5432/stock_picker
REDIS_URL=redis://localhost:6379/0

# Market data providers
FMP_API_KEY=<set-in-local-env>
ALPHA_VANTAGE_API_KEY=<set-in-local-env>
FINNHUB_API_KEY=<set-in-local-env>

# Notifications
DISCORD_WEBHOOK_URL=<set-in-local-env>
